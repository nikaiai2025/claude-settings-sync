{
  "permissions": {
    "allow": [
      "mcp__pencil",
      "*",
      "Read",
      "Edit",
      "Write",
      "Bash",
      "Glob",
      "Grep",
      "Agent",
      "WebSearch",
      "WebFetch",
      "Skill",
      "NotebookEdit"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-rm.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path') && [[ $FILE == *.ts || $FILE == *.tsx || $FILE == *.js || $FILE == *.jsx ]] && biome format --write $FILE && biome check --fix $FILE || true"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path') && [[ $FILE == *.py ]] && ruff check --fix $FILE && ruff format $FILE || true"
          }
        ]
      }
    ]
  },
  "autoUpdatesChannel": "latest",
  "mcpServers": {},
  "model": "opus",
  "effortLevel": "max"
}
